{
  "manifest_version": 3,
  "name": "Job Seeker – Tech Roles",
  "version": "1.0.0",
  "description": "Scrape and track software engineering apprenticeships, internships, and entry-level roles from LinkedIn, Indeed, and top tech companies.",
  "permissions": ["storage", "tabs", "scripting", "activeTab", "contextMenus"],
  "host_permissions": [
    "*://*/*",
    "http://localhost:11434/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
